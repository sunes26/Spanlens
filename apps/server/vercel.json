{
  "installCommand": "npm install",
  "buildCommand": "mkdir -p _server && npx esbuild src/handler.ts --bundle --platform=browser --target=es2022 --outfile=_server/index.js --format=esm --conditions=workerd,edge-light,browser",
  "rewrites": [{ "source": "/(.*)", "destination": "/_server/index" }]
}
