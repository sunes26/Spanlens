# Server
PORT=3001

# Supabase (로컬: supabase start 후 출력값 사용)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>

# 암호화 키: openssl rand -base64 32 으로 생성 (반드시 32바이트)
# 잘못 설정 시 Provider Key 복호화가 조용히 실패함 (빈 문자열 반환)
ENCRYPTION_KEY=<32-bytes-base64-encoded-key>

# Resend (이메일 알림, Phase 2)
RESEND_API_KEY=

# Paddle (Merchant of Record, 결제, Phase 2)
# Stripe 대신 Paddle 사용 이유: 한국 개인사업자는 Stripe 가입 불가 + Paddle이 글로벌 VAT/세금 자동 처리
# API key: Paddle Dashboard → Developer Tools → Authentication → API Keys
# Notification secret: Paddle Dashboard → Developer Tools → Notifications → secret 값 (webhook 서명 검증용)
PADDLE_API_KEY=
PADDLE_NOTIFICATION_SECRET=
# Sandbox: Paddle Sandbox 환경을 쓰면 'sandbox', 프로덕션은 'production'
PADDLE_ENVIRONMENT=sandbox
