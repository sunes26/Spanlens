# ── Spanlens-issued API key (sl_live_... or sl_test_...) ──────────────────
# Get from: https://www.spanlens.io/projects → your project → "Create API key"
SPANLENS_API_KEY=

# ── Spanlens dashboard JWT (for polling /api/v1/requests in benchmark.ts) ─
# How to get:
#   1. Open https://www.spanlens.io/requests in your browser, log in
#   2. DevTools → Application → Cookies → copy `sb-access-token` value
# (Only needed for benchmark.ts, NOT for individual provider tests.)
SPANLENS_JWT=

# ── Spanlens proxy server (override only for self-hosted) ─────────────────
SPANLENS_PROXY_BASE=https://spanlens-server.vercel.app
SPANLENS_API_BASE=https://www.spanlens.io

# ── Provider keys are registered in the Spanlens dashboard, NOT here. ─────
# The SDK sends SPANLENS_API_KEY only — Spanlens server decrypts and uses
# the matching provider key on your behalf. So you do NOT put your real
# OpenAI / Anthropic / Gemini key in this file.
