{
  "name": "@spanlens/sdk",
  "version": "0.2.4",
  "description": "Spanlens SDK — agent tracing, LLM usage capture, and cost observability for TypeScript.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./openai": {
      "import": "./dist/integrations/openai.js",
      "types": "./dist/integrations/openai.d.ts"
    },
    "./anthropic": {
      "import": "./dist/integrations/anthropic.js",
      "types": "./dist/integrations/anthropic.d.ts"
    },
    "./gemini": {
      "import": "./dist/integrations/gemini.js",
      "types": "./dist/integrations/gemini.d.ts"
    }
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run test",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "@anthropic-ai/sdk": ">=0.24.0",
    "@google/generative-ai": ">=0.20.0"
  },
  "peerDependenciesMeta": {
    "openai": { "optional": true },
    "@anthropic-ai/sdk": { "optional": true },
    "@google/generative-ai": { "optional": true }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@google/generative-ai": "^0.21.0",
    "@types/node": "^20.16.11",
    "openai": "^4.77.0",
    "typescript": "^5.4.5",
    "vitest": "^2.1.3"
  },
  "keywords": [
    "llm",
    "llm-observability",
    "llm-monitoring",
    "llm-tracing",
    "openai",
    "openai-sdk",
    "anthropic",
    "claude",
    "gemini",
    "google-generative-ai",
    "observability",
    "observability-sdk",
    "tracing",
    "agent-tracing",
    "ai-agents",
    "cost-tracking",
    "token-tracking",
    "langchain",
    "llamaindex",
    "vercel-ai",
    "ai-sdk",
    "next.js",
    "nextjs",
    "typescript",
    "helicone-alternative",
    "langfuse-alternative",
    "langsmith-alternative",
    "proxy",
    "baseurl",
    "spanlens"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunes26/Spanlens.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/sunes26/Spanlens/issues"
  },
  "homepage": "https://spanlens.io",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
