{
  "name": "@spanlens/cli",
  "version": "0.1.1",
  "description": "Spanlens onboarding wizard — one-command setup for LLM observability.",
  "type": "module",
  "bin": {
    "spanlens": "./dist/index.js",
    "create-spanlens": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run test"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "picocolors": "^1.1.1",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "tsx": "^4.19.1",
    "typescript": "^5.4.5",
    "vitest": "^2.1.3"
  },
  "keywords": [
    "spanlens",
    "llm",
    "observability",
    "cli",
    "wizard",
    "onboarding"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunes26/Spanlens.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/sunes26/Spanlens/issues"
  },
  "homepage": "https://spanlens.io",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
